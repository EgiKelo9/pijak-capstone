# =========================================================================
# GLOBAL / DATABASE CONFIGURATIONS
# =========================================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=beez_pijak_db
DATABASE_URL=postgresql://postgres:postgres@db:5432/beez_pijak_db
DATABASE_NAME=beez_pijak_db

# Environment settings (dev, test, prod)
ENV=prod

# =========================================================================
# BACKEND SERVICE CONFIGURATIONS
# =========================================================================
BACKEND_BASE_URL=http://backend:5000
ML_SERVICE_URL=http://ml_services:8000

# Security Configurations (JWT Access Tokens)
SECRET_KEY=generate_a_secure_random_key_here_for_production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# =========================================================================
# ML SERVICE CONFIGURATIONS
# =========================================================================
PORT=8000

# LLM Config (OpenRouter)
OPEN_ROUTER_BASE_URL=https://openrouter.ai/api/v1/chat/completions
OPEN_ROUTER_API_KEY=your_openrouter_api_key
LLM_MODEL=nvidia/nemotron-3-super-120b-a12b:free

# Internal ML Service API Key (digunakan oleh ml_services untuk auth ke backend)
# Key yang sama harus di-set di backend dan ml_services
# Generate dengan: python -c "import secrets; print(secrets.token_urlsafe(32))"
ML_API_KEY=generate_a_secure_random_key_here_for_ml_service

# =========================================================================
# FRONTEND SERVICE CONFIGURATIONS (Next.js)
# =========================================================================
# URL accessible from client browser (e.g. http://localhost:5000/api/v1 in local dev)
NEXT_PUBLIC_API_URL=http://localhost:5000/api/v1
NEXT_PUBLIC_ML_API_URL=http://localhost:8000/ml/v1
